# AI Console 环境变量 / Environment Variables
# 生产环境请修改此文件 / Edit this file for production use

# 管理员密码，默认 admin
# Admin password, default: admin
BOOTSTRAP_ADMIN_PASS=admin

# 管理员用户名，默认 admin
# Admin username, default: admin
# BOOTSTRAP_ADMIN_USER=admin

# ===== 以下为生产环境推荐配置 / Recommended for production =====
# 取消注释并设为强随机值，同时取消 NODE_ENV 注释
# Uncomment and set strong random values, also uncomment NODE_ENV

# NODE_ENV=production
# MASTER_KEY=change-me-to-a-random-64-char-string
# JWT_SECRET=change-me-to-another-random-64-char-string

# ===== 可选 / Optional =====
# GitHub Token，用于私有仓库 Agent 二进制代理
# GitHub token for private repo agent binary proxy
# GITHUB_TOKEN=github_token_here
